# =================================================================
# EZ Pilot — Environment Variables
# Copy to .env and fill in actual values. NEVER commit .env.
# =================================================================

# ---- App ----
NODE_ENV=production
PORT=5000
APP_URL=https://ez-pilot.com
API_URL=https://api.ez-pilot.com

# ---- JWT / Session ----
JWT_SECRET=                    # 64+ char random string
JWT_EXPIRY=7d
COOKIE_SECRET=                 # 64+ char random string

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://user:pass@host:5432/ezpilot

# ---- Redis (rate limit, queues, cache) ----
REDIS_URL=redis://localhost:6379

# ---- Firebase Admin ----
FIREBASE_PROJECT_ID=ez-pilot-c321c
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=ez-pilot-c321c.firebasestorage.app

# ---- AI Providers (official endpoints) ----
ANTHROPIC_API_KEY=             # sk-ant-... from https://console.anthropic.com
OPENAI_API_KEY=                # sk-... from https://platform.openai.com
GOOGLE_API_KEY=                # from https://aistudio.google.com
XAI_API_KEY=                   # xai-... from https://console.x.ai
DEEPSEEK_API_KEY=              # sk-... from https://platform.deepseek.com
MISTRAL_API_KEY=               # from https://console.mistral.ai

# ---- OAuth (ecosystem-level) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.ez-pilot.com/api/auth/oauth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://api.ez-pilot.com/api/auth/oauth/microsoft/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://api.ez-pilot.com/api/auth/oauth/facebook/callback

META_APP_ID=
META_APP_SECRET=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ---- Stripe (billing + webhook triggers) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=price_
STRIPE_PRICE_PRO_ANNUAL=price_
STRIPE_PRICE_MAX_MONTHLY=price_
STRIPE_PRICE_MAX_ANNUAL=price_

# ---- Make.com (workflow engine) ----
MAKE_WEBHOOK_URL_CHAT=
MAKE_WEBHOOK_URL_TRIGGERS=
MAKE_WEBHOOK_URL_TASKS=

# ---- Email (SMTP) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@ez-pilot.com
ADMIN_EMAIL=dcev6853@gmail.com

# ---- Observability ----
LOG_LEVEL=info
SENTRY_DSN=

# ---- Ollama (self-hosted LLMs) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
