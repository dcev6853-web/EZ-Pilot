rules_version = '2';

// =================================================================
// EZ Pilot — Cloud Storage Rules
// Users can only read/write their own uploads.
// =================================================================

service firebase.storage {
  match /b/{bucket}/o {

    // User uploads: /uploads/{uid}/{filename}
    match /uploads/{uid}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == uid
                        && request.resource.size < 100 * 1024 * 1024;  // 100 MB cap per file
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
